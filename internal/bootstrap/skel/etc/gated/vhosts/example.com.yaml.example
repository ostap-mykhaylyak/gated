# gated - example virtual host.
#
# One file = one virtual host. Copy to <name>.yaml to activate (the
# .example suffix is ignored). Files are reloaded on change; an invalid
# file is skipped and logged, the other vhosts keep serving. Manageable
# by hand or via the REST API (PUT /vhosts/example.com).
#
# NOTE: schema shipped ahead of implementation - the proxy engine is
# under development.

hosts: ["example.com", "www.example.com"]

tls:
  cert_name: ""            # default: letsencrypt_dir/<first host>; set to force another name
  cert_file: ""            # full override outside letsencrypt (optional)
  key_file: ""

redirect_to_https: true

# CMS behind gated (WordPress, etc.): gated terminates TLS and tells the
# backend the request was HTTPS via X-Forwarded-Proto/Ssl/Port, and
# rewrites http:// self-redirects to https:// — this prevents the
# classic "redirect loop" when the CMS is configured for HTTPS but gated
# reaches it over HTTP. If the CMS still loops, either add to
# wp-config.php:
#   if (($_SERVER['HTTP_X_FORWARDED_PROTO'] ?? '') === 'https') $_SERVER['HTTPS']='on';
# or point the backend url at the CMS's own https:// port (see below).

early_hints: []            # 103 hints sent before the backend responds
  # - "</assets/app.css>; rel=preload; as=style"

backends:
  # url carries scheme + address + port. The backend may live on any
  # IP/host, not just 127.0.0.1, and on any port. Use https:// to proxy
  # to a TLS backend (e.g. its own :443).
  - url: "http://192.168.1.50:8080"
    weight: 2
  - url: "http://192.168.1.51:8080"
    weight: 1
  - url: "https://10.0.0.9:443"     # HTTPS backend
    backup: true                    # only used when all primary backends are down

backend_tls:                 # only relevant for https:// backends
  # server_name: "example.com"      # SNI / cert name when addressing a backend by IP
  insecure_skip_verify: false       # true = accept self-signed backend certs (trusted LAN only)

load_balancing:
  strategy: "round_robin"  # round_robin | least_conn | ip_hash | uri_hash | random
  sticky:
    enabled: false
    cookie: "gated_affinity"
    ttl: "1h"
  health:                  # omitted = inherit the global defaults
    passive:
      max_fails: 3
      cooldown: "30s"
    active:
      enabled: false
      path: "/healthz"
      interval: "10s"
      timeout: "2s"
      expect_status: 200

compression: {}            # omitted/empty = inherit the global defaults

waf:                       # omitted = inherit the global WAF settings
  # enabled: true          # force on/off for this vhost
  # mode: detect           # block | detect (override global)
  exclude: []              # rule IDs to skip on this vhost, e.g. ["942100"]
