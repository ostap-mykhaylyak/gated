# gated - minimal reverse-proxy virtual host.
#
# gated listens on both :80 (HTTP) and :443 (HTTPS) — see entrypoints
# in config.yaml. It serves this vhost on both and, by default,
# preserves the request scheme to the backend: an HTTP request goes to
# an http:// backend, an HTTPS request to an https:// backend. That way
# the origin (CMS/nginx) decides whether to redirect — gated does not
# force it. Copy to <name>.yaml to enable.

hosts: ["example.com", "www.example.com"]

# List a backend per scheme so gated can preserve it end-to-end. The
# url carries scheme + host + port. For an https:// backend addressed
# by IP (local nginx), SNI / cert name auto-derive from the first host,
# so no backend_tls is needed.
backends:
  - url: "http://127.0.0.1:80"    # HTTP requests land here (nginx may 301 to https)
  - url: "https://127.0.0.1:443"  # HTTPS requests land here (the site)

# Optional overrides:
#
# redirect_to_https: true   # force http->https at the edge, instead of
#                           # letting the backend decide. Only enable if
#                           # the host has a certificate.
#
# backend_tls:              # only for a self-signed backend certificate
#   insecure_skip_verify: true
#
# For an HTTP-only site: list just the http:// backend (no cert needed).
