# Rotation policy for gated. The daemon has no rotation logic: on
# SIGHUP (systemctl reload) it reopens every *.log file. Runtime state
# (non-.log) is excluded by the glob.
/var/log/gated/*.log {
    daily
    rotate 14
    compress
    delaycompress
    missingok
    notifempty
    create 0640 root root
    sharedscripts
    postrotate
        systemctl reload gated.service >/dev/null 2>&1 || true
    endscript
}
